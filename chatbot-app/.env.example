# Copy this file to ".env" and fill in your key (never commit the real .env).
# With no key set, the app runs in demo mode (answers straight from the knowledge base).

# Your OpenAI API key — enables real RAG answers.
OPENAI_API_KEY=

# Optional: override the model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: port (default: 3000)
PORT=3000
